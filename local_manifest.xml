<?xml version="1.0" encoding="UTF-8"?>
<manifest>

 <!-- unitrix_kernel -->
 <remote name="unitrix_kernel"
	 fetch="https://github.com/GhostMaster69-dev" />

 <!-- dib_repos -->
 <remote name="dib_repos"
	 fetch="https://github.com/dib12" />

 <!-- Device tree -->
 <project path="device/xiaomi/vince" name="android_device_xiaomi_vince" remote="dib_repos" revision="lineage-20" clone-depth="1" />
 <project path="vendor/xiaomi/vince" name="proprietary_vendor_xiaomi_vince" remote="dib_repos" revision="lineage-20" clone-depth="1" />
 <project path="device/xiaomi/msm8953-common" name="device_xiaomi_msm8953-common" remote="dib_repos" revision="lineage-20" clone-depth="1" />
 <project path="vendor/xiaomi/msm8953-common" name="vendor_xiaomi_msm8953-common" remote="dib_repos" revision="lineage-20" clone-depth="1" />
 <project path="vendor/dolby/ds" name="vendor_dolby_ds" remote="dib_repos" revision="lineage-20" clone-depth="1" />
 <project path="kernel/xiaomi/msm8953" name="android_kernel_xiaomi_vince" remote="unitrix_kernel" revision="master" clone-depth="1" />

 <!-- custom android_build -->
 <remove-project name="LineageOS/android_build" />
 <project path="build/make" name="android_build" remote="dib_repos" revision="lineage-20.0" clone-depth="1" >
    <linkfile src="CleanSpec.mk" dest="build/CleanSpec.mk" />
    <linkfile src="buildspec.mk.default" dest="build/buildspec.mk.default" />
    <linkfile src="core" dest="build/core" />
    <linkfile src="envsetup.sh" dest="build/envsetup.sh" />
    <linkfile src="target" dest="build/target" />
    <linkfile src="tools" dest="build/tools" />
  </project>
</manifest>
